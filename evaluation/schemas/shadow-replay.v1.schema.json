{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:codex-opc-team:schema:shadow-replay:v1",
  "title": "OPC Shadow Evaluation replay input",
  "type": "object",
  "required": ["schema_version", "contract_version", "evaluation_id", "dataset", "candidate", "dependency", "cases"],
  "properties": {
    "schema_version": {"const": "opc-shadow-replay-v1"},
    "contract_version": {"const": "opc-shadow-evaluation-contract-v1"},
    "evaluation_id": {"$ref": "#/$defs/portableId"},
    "dataset": {"$ref": "#/$defs/dataset"},
    "candidate": {"$ref": "#/$defs/candidate"},
    "dependency": {"$ref": "#/$defs/dependency"},
    "cases": {"type": "array", "minItems": 1, "maxItems": 20, "items": {"$ref": "#/$defs/case"}}
  },
  "$defs": {
    "portableId": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$"},
    "portableRef": {"type": "string", "minLength": 1, "maxLength": 240, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*//)(?!.*(?:^|/)\\.{1,2}(?:/|$))[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"},
    "dataset": {
      "type": "object",
      "required": ["kind", "dataset_id", "project_id", "approval_ref"],
      "properties": {
        "kind": {"enum": ["synthetic", "approved_private_pilot"]},
        "dataset_id": {"$ref": "#/$defs/portableId"},
        "project_id": {"$ref": "#/$defs/portableId"},
        "approval_ref": {"type": ["string", "null"], "maxLength": 240}
      },
      "additionalProperties": false
    },
    "candidate": {
      "type": "object",
      "required": ["candidate_id", "source_path", "source_commit", "content_sha256"],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^exp-[A-Za-z0-9._-]+$", "maxLength": 128},
        "source_path": {"$ref": "#/$defs/portableRef"},
        "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "dependency": {
      "type": "object",
      "required": ["engine", "version", "determinism", "seed"],
      "properties": {
        "engine": {"$ref": "#/$defs/portableId"},
        "version": {"$ref": "#/$defs/portableId"},
        "determinism": {"enum": ["deterministic", "versioned_nondeterministic"]},
        "seed": {"type": ["string", "null"], "maxLength": 128}
      },
      "additionalProperties": false
    },
    "ratio": {
      "type": "object",
      "required": ["numerator", "denominator"],
      "properties": {
        "numerator": {"type": "integer", "minimum": 0},
        "denominator": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "arm": {
      "type": "object",
      "required": ["candidate_applied", "execution_status", "failure_code", "metrics"],
      "properties": {
        "candidate_applied": {"type": "boolean"},
        "execution_status": {"enum": ["completed", "timeout", "provider_unavailable", "provider_error"]},
        "failure_code": {"type": ["string", "null"], "maxLength": 128},
        "metrics": {
          "type": "object",
          "required": ["manager_intervention_rate", "qa_catch_rate", "rework_loops_per_task", "valid_knowledge_reuse_rate", "false_recall_rate", "scope_leakage_acceptances", "stale_obsolete_acceptances", "context_tokens_per_task", "latency_ms"],
          "properties": {
            "manager_intervention_rate": {"$ref": "#/$defs/ratio"},
            "qa_catch_rate": {"$ref": "#/$defs/ratio"},
            "rework_loops_per_task": {"$ref": "#/$defs/ratio"},
            "valid_knowledge_reuse_rate": {"$ref": "#/$defs/ratio"},
            "false_recall_rate": {"$ref": "#/$defs/ratio"},
            "scope_leakage_acceptances": {"type": "integer", "minimum": 0},
            "stale_obsolete_acceptances": {"type": "integer", "minimum": 0},
            "context_tokens_per_task": {"type": "integer", "minimum": 1},
            "latency_ms": {"type": "number", "exclusiveMinimum": 0}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "case": {
      "type": "object",
      "required": ["case_id", "control", "treatment"],
      "properties": {
        "case_id": {"$ref": "#/$defs/portableId"},
        "control": {"$ref": "#/$defs/arm"},
        "treatment": {"$ref": "#/$defs/arm"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
